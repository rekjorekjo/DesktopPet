#include <windows.h>

IDI_ICON1 ICON "@CMAKE_CURRENT_SOURCE_DIR@/resources/icons/app_icon.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @DESKTOPPET_VERSION_MAJOR@,@DESKTOPPET_VERSION_MINOR@,@DESKTOPPET_VERSION_PATCH@,@DESKTOPPET_VERSION_BUILD@
 PRODUCTVERSION @DESKTOPPET_VERSION_MAJOR@,@DESKTOPPET_VERSION_MINOR@,@DESKTOPPET_VERSION_PATCH@,@DESKTOPPET_VERSION_BUILD@
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "DesktopPet Team"
            VALUE "FileDescription", "DesktopPet Resize Tool"
            VALUE "FileVersion", "@DESKTOPPET_VERSION_DISPLAY@"
            VALUE "InternalName", "DesktopPet-resize"
            VALUE "OriginalFilename", "DesktopPet-resize.exe"
            VALUE "ProductName", "DesktopPet"
            VALUE "ProductVersion", "@DESKTOPPET_VERSION_TAG@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
